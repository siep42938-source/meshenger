# ═══════════════════════════════════════════════════════════════════
# Umberla — переменные окружения
# Скопируй этот файл в .env и заполни значения
# ═══════════════════════════════════════════════════════════════════

# ─── Telegram Bot ────────────────────────────────────────────────
# 1. Открой @BotFather в Telegram
# 2. Напиши /newbot и следуй инструкциям
# 3. Скопируй токен сюда
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Твой Telegram ID (узнать у @userinfobot)
ADMIN_TELEGRAM_ID=your_telegram_id_here

# ─── Публичный URL ───────────────────────────────────────────────
# URL где задеплоен фронтенд (React приложение)
# Пример: https://umberla-app.onrender.com
# ВАЖНО: без слеша в конце!
# Если не задан — кнопка в боте будет вести на заглушку
APP_URL=https://your-frontend-domain.com

# ─── Webhook для Telegram бота ───────────────────────────────────
# URL этого сервера (бэкенда)
# Пример: https://umberla-server.onrender.com
# После деплоя сервер автоматически зарегистрирует webhook
WEBHOOK_URL=https://your-backend-domain.com

# ─── Прочее ──────────────────────────────────────────────────────
# Ссылка на исходный код (GitHub)
SOURCE_URL=https://github.com/umberla/messenger

# Порт сервера (Render/Railway подставят свой автоматически)
PORT=3001

# Окружение (production / development)
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════
# КАК ЗАДЕПЛОИТЬ БЕСПЛАТНО (Render.com):
#
# 1. Зарегистрируйся на https://render.com
# 2. New → Blueprint → подключи GitHub репозиторий
# 3. Render найдёт render.yaml и создаст оба сервиса автоматически
# 4. В настройках сервиса umberla-server добавь переменные:
#    - TELEGRAM_BOT_TOKEN
#    - ADMIN_TELEGRAM_ID
#    - APP_URL (URL фронтенда из umberla-app)
#    - WEBHOOK_URL (URL бэкенда из umberla-server)
# 5. Готово! Бот заработает, ссылки появятся автоматически
# ═══════════════════════════════════════════════════════════════════
